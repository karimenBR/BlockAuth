# ─────────────────────────────────────────────
#  BlockAuth — Environment Configuration
# ─────────────────────────────────────────────
#  Copy this file to .env and fill in your values
# ─────────────────────────────────────────────

# Server
PORT=3000
NODE_ENV=development

# JWT Secret — generate with: openssl rand -hex 64
JWT_SECRET=4651328456123984561234561
JWT_EXPIRES_IN=1h

# Redis — session and OTP state store
REDIS_URL=redis://localhost:6379
# For Redis Cloud / Upstash:
# REDIS_URL=rediss://:password@host:port

# SIWE / Ethereum
# The domain your frontend runs on (used in SIWE message validation)
SIWE_DOMAIN=http://localhost:5175/
SIWE_STATEMENT=Sign in to BlockAuth

# OTP Settings
OTP_LENGTH=6
OTP_TTL_SECONDS=600          # 5 minutes
OTP_MAX_ATTEMPTS=3           # Hard block after 3 wrong attempts

# SendGrid (Email)
EMAIL_FROM=karimenbenromdhane55@gmail.com
GMAIL_APP_PASSWORD=xwiirokhffvmpeoc
EMAIL_FROM_NAME=BlockAuth Security

# Twilio (SMS)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_FROM_NUMBER=+21693779503

# Risk Thresholds (Agent 2)
RISK_LOW_MAX=30              # 0–30 = LOW
RISK_MEDIUM_MAX=70           # 31–70 = MEDIUM
# 71–100 = CRITICAL

# Geo Velocity (Agent 1)
# Max km/h considered physically possible (commercial flight ~900)
MAX_TRAVEL_SPEED_KPH=900

# IP Reputation API (optional — AbuseIPDB)
ABUSEIPDB_API_KEY=your_abuseipdb_key_here

# Platform API Keys
# Platforms that integrate BlockAuth register here and get an API key
# In production, store these in DB. For now, comma-separated list:
PLATFORM_API_KEYS=test-platform-key-123,ffdeabe6234b4e62814fcbd58791581f

# Webhook (optional — notify platforms of auth events)
WEBHOOK_ENABLED=false
WEBHOOK_SECRET=your_webhook_secret
